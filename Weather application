import tkinter
import requests
from tkinter import messagebox
from PIL import Image, ImageTk

API_KEY = "YOUR_API_KEY"

def user_citybuttonuse():

    city = user_cityselection.get().strip()

    if city == "":
        messagebox.showerror(
            "Error",
            "Please enter a city name"
        )
        return

    url = (
        f"https://api.openweathermap.org/data/2.5/weather"
        f"?q={city}"
        f"&appid={API_KEY}"
        f"&units=metric"
    )

    reply = requests.get(url)

    reply_json = reply.json()

    if str(reply_json["cod"]) != "200":
        messagebox.showerror(
            "Error",
            "Enter Correct City Name"
        )
        return

    celsius = reply_json["main"]["temp"]

    humidity = reply_json["main"]["humidity"]

    wind_speed = round(
        reply_json["wind"]["speed"] * 3.6,
        1
    )

    weather = reply_json["weather"][0]["main"]

    city_name = reply_json["name"]

    weather_label.config(
        text=
        f"Temperature : {celsius} °C\n\n"
        f"Humidity : {humidity}%\n\n"
        f"Wind Speed : {wind_speed} km/h\n\n"
        f"Weather Condition : {weather}\n\n"
        f"City Name : {city_name}"
    )

app = tkinter.Tk()

app.geometry("400x500")

app.title("Weather Forecast Application")

image_path = "weather_appbg.jpg"

image = Image.open(image_path)

image = image.resize((400, 500))

bg_image = ImageTk.PhotoImage(image)

set_image = tkinter.Label(
    app,
    image=bg_image
)

set_image.place(
    x=0,
    y=0,
    relwidth=1,
    relheight=1
)

name_label = tkinter.Label(
    app,
    text="Weather Forecast Application",
    font=("Georgia", 14, "bold")
)

name_label.pack(pady=10)

user_cityselection = tkinter.Entry(
    app,
    width=30,
    font=("Arial", 12)
)

user_cityselection.pack(pady=10)

user_citybutton = tkinter.Button(
    app,
    text="Get Weather",
    command=user_citybuttonuse
)

user_citybutton.pack(pady=10)

weather_label = tkinter.Label(
    app,
    text="",
    width=28,
    height=12,
    relief="solid",
    borderwidth=2,
    font=("Georgia", 10),
    justify="left"
)

weather_label.pack(pady=10)

app.mainloop()
